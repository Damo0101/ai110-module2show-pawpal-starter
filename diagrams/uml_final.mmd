classDiagram
    class Owner {
        +str name
        +dict preferences
        +int available_minutes
        +list~Pet~ pets
        +add_pet(pet) None
        +remove_pet(pet) None
        +set_preference(key, value) None
        +set_available_time(minutes) None
        +all_tasks() list
    }

    class Pet {
        +str name
        +str species
        +str breed
        +int age
        +str notes
        +list~Task~ tasks
        +add_task(task) None
        +remove_task(task) None
        +edit_task(task, changes) None
        +list_tasks() list~Task~
        +complete_task(task) Task
    }

    class Task {
        +str title
        +int duration_minutes
        +str priority
        +str category
        +str frequency
        +str preferred_time
        +bool completed
        +date due_date
        +priority_score() int
        +is_due_today() bool
        +mark_complete() None
        +next_occurrence() Task
        +update(changes) None
    }

    class Scheduler {
        +Owner owner
        +str start_time
        +int available_minutes
        +list tasks
        +sort_tasks() list
        +sort_by_time() list
        +filter_tasks() list
        +filter_by_pet(pet_name) list
        +filter_by_status(completed) list
        +detect_conflicts() list~str~
        +resolve_conflicts(selected) list
        +build_plan() list
        +explain_plan() str
    }

    Owner "1" o-- "1..*" Pet : has
    Pet "1" *-- "0..*" Task : has
    Pet ..> Task : creates next occurrence
    Scheduler --> Owner : reads constraints
    Scheduler ..> Pet : pools tasks by pet
    Scheduler ..> Task : sorts / filters / schedules
